      Hint = 'When "include" is checked user can type in a letter or string (search item) and all'#10'hits are shown where the search item is found in any place of target(s).'#10'.'#10'User can make more specified search adding % or _  (or both) to search item:'#10'% represents any string '#10'_  represents any single letter'#10'.'#10'EXAMPLE:'#10'OH1%  (finds all OH1 callsigns)'#10'OH_KH (finds OH1KH,OH2KH,OH3KH etc...)'#10'OH_K%(finds all OH [any number] K [any letter(s) after K] )'#10'.'#10'Same functions with Name and Qth search.'
